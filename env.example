# ==========================================
# 🛡️ ORIORIS BUNKER - VARIABLES D'ENVIRONNEMENT
# ==========================================
# Renommez ce fichier en '.env' et remplacez les valeurs par les vôtres.

# 🔌 ROUTAGE LLM (LiteLLM)
# Mettez ici l'adresse de votre proxy LiteLLM (ou l'API d'OpenAI/Anthropic)
LITELLM_API_BASE="http://litellm_bunker:4000/v1"
LITELLM_API_KEY="votre_cle_api_securisee_ici"

# 🌐 RECHERCHE (SearXNG)
# L'URL de votre instance SearXNG locale
SEARXNG_BASE_URL="http://searxng_bunker:8080"

# ⚙️ ARMURERIE N8N
# L'URL exacte du Webhook n8n qui écoute les requêtes MCP
MCP_N8N_URL="http://n8n:5678/mcp/votre_webhook_id_ici"

# 🔒 PARAMÈTRES SYSTÈME ET TÉLÉMÉTRIE
# Coupe l'envoi de données vers les serveurs de CrewAI
CREWAI_TELEMETRY_OPT_OUT=true
PYTHONUNBUFFERED=1
