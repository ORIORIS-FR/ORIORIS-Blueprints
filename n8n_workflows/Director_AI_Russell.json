    {
      "parameters": {
        "content": "## [🔊Mungo's Hi Fi xBANTON](https://www.youtube.com/nuMILNA3v6k)\n@[youtube](nuMILNA3v6k)\n",
        "height": 240,
        "width": 624
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        1152,
        -1392
      ],
      "typeVersion": 1,
      "id": "a6d5c591-e32a-4502-b5d5-260ee781d9c0",
      "name": "Sticky Note3"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet contenuGlobal = \"\";\nlet resumeGlobal = \"\";\n\n// 1. Fusion de toutes les analyses de la nuit\nfor (let item of items) {\n    if (item.json.rapport_complet) {\n        contenuGlobal += item.json.rapport_complet + \"\\n\\n---\\n\\n\";\n        resumeGlobal += \"✅ \" + item.json.resume_telegram + \"\\n\\n\";\n    }\n}\n\n// 2. Création du Frontmatter\nconst dateJour = new Date().toISOString().split('T')[0];\nconst frontmatter = `---\ntitle: \"Rapport Maître Russell - ${dateJour}\"\ndate: ${dateJour}\nstatus: 🟢_a_lire\ntype: 🤖_rapport_quotidien\ntags:\n  - SYSTEME/Russell\n  - RAG/audit\n---\n\n# 🧠 Synthèse Nocturne du Bunker\n\n`;\n\n// 3. Génération du lot unique (1 seul message Telegram, 1 seul fichier)\nreturn {\n    json: {\n        resume_telegram_final: \"🚨 **Rapport de la Nuit** 🚨\\n\\n\" + resumeGlobal\n    },\n    binary: {\n        data: {\n            data: Buffer.from(frontmatter + contenuGlobal, 'utf8').toString('base64'),\n            mimeType: 'text/markdown',\n            fileName: 'rapport.md'\n        }\n    }\n};"
      },
      "type": "n8n-nodes-base.code",
